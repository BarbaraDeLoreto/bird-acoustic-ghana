recording_span <- bn_w[subplot_ID %in% subplots_in_analysis] |>
filter(!startsWith(subplot_ID, "C102")) |>
group_by(subplot_ID) |>
summarise(
first_detection = min(detection_datetime),
last_detection  = max(detection_datetime),
.groups = "drop"
) |>
mutate(
included   = ifelse(subplot_ID %in% subplots_18h_ok, "Included", "Excluded"),
subplot_ID = factor(subplot_ID, levels = sort(unique(subplot_ID))),
# Convert to hours since 12:00 day 1 for plotting on a 0-24 scale
# 12:00 = 0, 24:00 = 12, 12:00 next day = 24
first_hour = as.numeric(difftime(first_detection,
as.POSIXct(paste(as.Date(first_detection), "12:00:00"),
tz = "Africa/Accra"),
units = "hours")),
last_hour  = as.numeric(difftime(last_detection,
as.POSIXct(paste(as.Date(first_detection), "12:00:00"),
tz = "Africa/Accra"),
units = "hours"))
)
# Y axis breaks and labels: 12:00 to 12:00 next day
hour_breaks <- seq(0, 24, by = 2)
hour_labels <- c("12:00", "14:00", "16:00", "18:00", "20:00", "22:00",
"00:00", "02:00", "04:00", "06:00", "08:00", "10:00", "12:00")
fig_duration <- ggplot(recording_span,
aes(x = subplot_ID, fill = included)) +
geom_rect(aes(xmin = as.numeric(subplot_ID) - 0.4,
xmax = as.numeric(subplot_ID) + 0.4,
ymin = first_hour,
ymax = last_hour)) +
scale_fill_manual(values = c("Included" = "#1B9E77",
"Excluded" = "grey70")) +
scale_y_continuous(breaks = hour_breaks,
labels = hour_labels,
limits = c(0, 24)) +
scale_x_discrete() +
labs(
x    = "Subplot",
y    = "Time of day",
fill = NULL,
title = "Recording duration per subplot (12:00 to 12:00 following day)"
) +
theme_classic() +
theme(
axis.text.x        = element_text(angle = 90, hjust = 1, vjust = 0.5, size = 7),
legend.position    = "bottom",
panel.grid.major.y = element_line(colour = "grey90")
)
fig_duration
