# ── Figure 3: Recording span Gantt chart ───────────────────────────────────────
# Build recording span from bn_w for subplots in analysis
recording_span <- bn_w[subplot_ID %in% subplots_in_analysis] |>
filter(!startsWith(subplot_ID, "C102")) |>
group_by(subplot_ID) |>
summarise(
first_detection = min(detection_datetime),
last_detection  = max(detection_datetime),
.groups = "drop"
) |>
mutate(
included = ifelse(subplot_ID %in% subplots_18h_ok, "Included", "Excluded"),
subplot_ID = factor(subplot_ID, levels = sort(unique(subplot_ID)))
)
# Common anchor: earliest first detection across all subplots
anchor_time <- min(recording_span$first_detection)
cat("Anchor time:", format(anchor_time), "\n")
# Convert to hours since anchor
recording_span <- recording_span |>
mutate(
first_hour = as.numeric(difftime(first_detection, anchor_time, units = "hours")),
last_hour  = as.numeric(difftime(last_detection,  anchor_time, units = "hours")),
# Cap at 30 hours for display
last_hour  = pmin(last_hour, 30)
)
# Y axis breaks and labels relative to anchor time
anchor_hour <- as.numeric(format(anchor_time, "%H")) +
as.numeric(format(anchor_time, "%M")) / 60
hour_breaks <- seq(0, 30, by = 2)
hour_labels <- format(
as.POSIXct(anchor_time) + hour_breaks * 3600,
"%H:%M"
)
# Plot
fig_duration <- ggplot(recording_span,
aes(x = subplot_ID, fill = included)) +
geom_rect(aes(xmin = as.numeric(subplot_ID) - 0.4,
xmax = as.numeric(subplot_ID) + 0.4,
ymin = first_hour,
ymax = last_hour)) +
scale_fill_manual(values = c("Included" = "#1B9E77",
"Excluded" = "grey70")) +
scale_y_continuous(breaks = hour_breaks,
labels = hour_labels,
limits = c(0, 30)) +
scale_x_discrete() +
labs(
x     = "Subplot",
y     = "Time of day",
fill  = NULL,
title = "Recording span per subplot"
) +
theme_classic() +
theme(
axis.text.x        = element_text(angle = 90, hjust = 1,
vjust = 0.5, size = 7),
legend.position    = "bottom",
panel.grid.major.y = element_line(colour = "grey90")
)
fig_duration
recording_span |>
select(subplot_ID, first_hour, last_hour, included) |>
arrange(first_hour) |>
print(n = 50)
recording_span <- bn_w[subplot_ID %in% subplots_in_analysis] |>
filter(!startsWith(subplot_ID, "C102")) |>
group_by(subplot_ID) |>
summarise(
first_detection = min(detection_datetime),
last_detection  = max(detection_datetime),
.groups = "drop"
) |>
mutate(
included   = ifelse(subplot_ID %in% subplots_18h_ok, "Included", "Excluded"),
subplot_ID = factor(subplot_ID, levels = sort(unique(subplot_ID))),
# Extract time of day in decimal hours - ignore date
first_hour = hour(first_detection) + minute(first_detection) / 60,
last_hour  = hour(last_detection)  + minute(last_detection)  / 60,
# Add 24 to last_hour if recording crosses midnight
last_hour  = ifelse(last_hour < first_hour, last_hour + 24, last_hour)
)
# Y axis: from earliest first_hour to 30h
y_min <- floor(min(recording_span$first_hour))
hour_breaks <- seq(y_min, y_min + 30, by = 2)
hour_labels <- sprintf("%02d:00", hour_breaks %% 24)
fig_duration <- ggplot(recording_span,
aes(x = subplot_ID, fill = included)) +
geom_rect(aes(xmin = as.numeric(subplot_ID) - 0.4,
xmax = as.numeric(subplot_ID) + 0.4,
ymin = first_hour,
ymax = last_hour)) +
scale_fill_manual(values = c("Included" = "#1B9E77",
"Excluded" = "grey70")) +
scale_y_continuous(breaks = hour_breaks,
labels = hour_labels,
limits = c(y_min, y_min + 30)) +
labs(
x     = "Subplot",
y     = "Time of day",
fill  = NULL,
title = "Recording span per subplot"
) +
theme_classic() +
theme(
axis.text.x        = element_text(angle = 90, hjust = 1,
vjust = 0.5, size = 7),
legend.position    = "bottom",
panel.grid.major.y = element_line(colour = "grey90")
)
fig_duration
