# parent directory
parent_dir <- "F:/Acoustic_Monitoring_Block_01/Short_Term_Block_02_silent"
file_name <- "recording_summary_Block_02.csv"
file_name_b <- "recording_summary_with_silence_Block_02.csv"

files <- list.files(parent_dir,
                    pattern="\\.wav$",
                    recursive=TRUE,
                    full.names=TRUE)

extract_info <- function(f){
  
  parts <- strsplit(f, .Platform$file.sep)[[1]]
  
  plot <- parts[length(parts)-3]
  point <- parts[length(parts)-2]
  
  file <- basename(f)
  
  ts <- regmatches(file, regexpr("\\d{8}T\\d{6}[+-]\\d{4}", file))
  
  date <- substr(ts,1,8)
  time <- substr(ts,10,15)
  
  date <- as.Date(date,"%Y%m%d")
  
  duration <- NA
  
  # safely read header
  try({
    h <- readWave(f, header=TRUE)
    duration <- h$samples / h$sample.rate
  }, silent=TRUE)
  
  data.frame(
    plot = plot,
    point = point,
    file = file,
    date = date,
    start_time = time,
    duration_seconds = duration,
    stringsAsFactors = FALSE
  )
}

results <- do.call(rbind, lapply(files, extract_info))

results$duration_minutes <- results$duration_seconds / 60

write.csv(results, file_name, row.names=FALSE)

head(results)

# check if recording are silent 

# Read a short window safely; returns NULL on any error
safe_read <- function(file, from, to) {
  tryCatch(
    readWave(file, from = from, to = to, units = "seconds"),
    error = function(e) NULL
  )
}

# Compute RMS for one Wave object (handles mono/stereo and 8/16-bit)
wave_rms <- function(w) {
  if (is.null(w)) return(NA_real_)
  
  # Combine channels: mono → left only; stereo → mean of both
  samples <- if (w@stereo) {
    (w@left + w@right) / 2
  } else {
    w@left
  }
  
  # Normalise: 8-bit PCM is unsigned (0-255, centred at 128)
  norm <- if (w@bit == 8) {
    (samples - 128) / 128
  } else {
    samples / (2^(w@bit - 1))
  }
  
  # Remove DC offset before RMS so hardware bias doesn't fake a signal
  norm <- norm - mean(norm, na.rm = TRUE)
  
  sqrt(mean(norm^2, na.rm = TRUE))
}

# Per-file function – samples start, middle and end of each recording
check_silence_robust <- function(file,
                                 sample_sec  = 10,
                                 min_dur_sec = 10) {
  
  h <- tryCatch(readWave(file, header = TRUE), error = function(e) NULL)
  
  if (is.null(h)) {
    return(data.frame(file = basename(file),
                      rms_min = NA_real_, rms_mean = NA_real_,
                      silent = NA, skipped = TRUE,
                      skip_reason = "read_error",
                      stringsAsFactors = FALSE))
  }
  
  duration <- h$samples / h$sample.rate
  
  if (duration < min_dur_sec) {
    return(data.frame(file = basename(file),
                      rms_min = NA_real_, rms_mean = NA_real_,
                      silent = NA, skipped = TRUE,
                      skip_reason = "too_short",
                      stringsAsFactors = FALSE))
  }
  
  # Three sample windows: start / mid / end
  mid_start  <- max(0, duration / 2 - sample_sec / 2)
  end_start  <- max(0, duration   - sample_sec)
  
  windows <- list(
    safe_read(file, 0,         min(sample_sec, duration)),
    safe_read(file, mid_start, mid_start + sample_sec),
    safe_read(file, end_start, duration)
  )
  
  rms_vals <- sapply(windows, wave_rms)           # length-3 vector
  rms_vals <- rms_vals[!is.na(rms_vals)]
  
  if (length(rms_vals) == 0) {
    return(data.frame(file = basename(file),
                      rms_min = NA_real_, rms_mean = NA_real_,
                      silent = NA, skipped = TRUE,
                      skip_reason = "all_windows_failed",
                      stringsAsFactors = FALSE))
  }
  
  data.frame(
    file        = basename(file),
    rms_min     = min(rms_vals),   # most conservative: quietest window
    rms_mean    = mean(rms_vals),
    silent      = NA,              # filled in after adaptive threshold step
    skipped     = FALSE,
    skip_reason = "",
    stringsAsFactors = FALSE
  )
}

# Collect raw RMS values 
message("Computing RMS for ", length(files), " files …")
results_silence <- do.call(rbind, lapply(files, check_silence_robust,
                                         sample_sec  = 10,
                                         min_dur_sec = 10))

# Adaptive threshold 
# Use the 5th-percentile of measured rms_min values as the silence cut-off.
# This is robust: genuine silent files cluster far below the bulk of recordings.
# You can raise the quantile (e.g. 0.10) if you still get false-negatives, or
# set a manual threshold by replacing the line below with:
#   silence_threshold <- 0.002   # adjust to your recorder / environment
valid_rms <- results_silence$rms_min[!is.na(results_silence$rms_min)]

silence_threshold <- if (length(valid_rms) >= 10) {
  quantile(valid_rms, probs = 0.05)
} else {
  # Fallback when very few files: use a small fixed value
  1e-3
}

message(sprintf("Adaptive silence threshold (5th pct of rms_min): %.6f", silence_threshold))

results_silence$silent[!results_silence$skipped] <-
  results_silence$rms_min[!results_silence$skipped] < silence_threshold

# Merge and export 
results_final <- left_join(results, results_silence, by = "file")

# Reorder columns for readability
results_final <- results_final[, c(
  "plot", "point", "file", "date", "start_time",
  "duration_seconds", "duration_minutes",
  "rms_min", "rms_mean", "silent", "skipped", "skip_reason"
)]

write.csv(results_final,
          file_name_b,
          row.names = FALSE)

message("Done. Silent files detected: ",
        sum(results_final$silent == TRUE, na.rm = TRUE),
        " / ",
        sum(!is.na(results_final$silent)))

head(results_final)
